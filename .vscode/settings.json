{
    "editor.renderWhitespace": "all",
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "python.analysis.autoFormatStrings": true,
    "python.analysis.autoImportCompletions": true,
    "python.analysis.extraPaths": [
        "tests/repo1/pylib",
        "tests/repo2/pylib"
    ],
    "python.testing.pytestArgs": [
        // pytest does not support both coverage and debugging at the same time. If coverage is desired, comment out the following line
        "--no-cov",
    ],
    "python.testing.pytestEnabled": true,
    "python.testing.cwd": "${workspaceFolder}",
    "ruff.interpreter": [
        "${workspaceFolder}/.venv/bin/python"
    ],
    "autoDocstring.startOnNewLine": true,
    // Biome is the formatter + organize-imports source for the web/ dashboard.
    // Scoped to TS/TSX/JS (which live only under web/) so it never touches the
    // repo's other JSON/CSS. web/ CSS + JSON format via `make format-ts`. The
    // Biome extension auto-resolves web/biome.json per file.
    "[typescript]": {
        "editor.defaultFormatter": "biomejs.biome",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports.biome": "explicit"
        }
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "biomejs.biome",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports.biome": "explicit"
        }
    },
    "[javascript]": {
        "editor.defaultFormatter": "biomejs.biome",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports.biome": "explicit"
        }
    },
    // Each git worktree under .claude/worktrees/ is a FULL checkout carrying its
    // own .venv and node_modules. Three worktrees = 15,559 directories = 96% of
    // everything the file watcher was tracking (the repo itself is ~633). Against
    // an fs.inotify.max_user_watches ceiling of 28,800, a handful of worktrees
    // blows straight through it and the watcher process balloons.
    "files.watcherExclude": {
        ".pytest_cache/**": true,
        ".nox/**": true,
        ".ruff_cache/**": true,
        ".venv/**": true,
        "**/node_modules/**": true,
        "web/coverage/**": true,
        ".claude/worktrees/**": true,
        ".superpowers/**": true,
        "reports/**": true
    },
    "search.exclude": {
        ".nox/**": true,
        ".venv/**": true,
        "**/node_modules/**": true,
        ".claude/worktrees/**": true,
        ".superpowers/**": true,
        "reports/**": true
    },
    // tsserver defaults to a 3072 MB heap, which is most of this 3.7 GB box's RAM.
    // web/ is small and does not need it. NOTE the key: the older
    // `typescript.tsserver.maxTsServerMemory` is deprecated in favour of this one.
    "js/ts.tsserver.maxMemory": 1024,
}
