{
    "editor.renderWhitespace": "all",
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "python.analysis.autoFormatStrings": true,
    "python.analysis.autoImportCompletions": true,
    "python.analysis.extraPaths": [
        "tests/repo1/pylib",
        "tests/repo2/pylib"
    ],
    "python.testing.pytestArgs": [
        // pytest does not support both coverage and debugging at the same time. If coverage is desired, comment out the following line
        "--no-cov",
    ],
    "python.testing.pytestEnabled": true,
    "python.testing.cwd": "${workspaceFolder}",
    "ruff.interpreter": [
        "${workspaceFolder}/.venv/bin/python"
    ],
    "autoDocstring.startOnNewLine": true,
    // Biome is the formatter + organize-imports source for the web/ dashboard.
    // Scoped to TS/TSX/JS (which live only under web/) so it never touches the
    // repo's other JSON/CSS. web/ CSS + JSON format via `make web-format`. The
    // Biome extension auto-resolves web/biome.json per file.
    "[typescript]": {
        "editor.defaultFormatter": "biomejs.biome",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports.biome": "explicit"
        }
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "biomejs.biome",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports.biome": "explicit"
        }
    },
    "[javascript]": {
        "editor.defaultFormatter": "biomejs.biome",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports.biome": "explicit"
        }
    },
    "files.watcherExclude": {
        ".pytest_cache/**": true,
        ".nox/**": true,
        ".ruff_cache/**": true,
        ".venv/**": true,
        "web/node_modules/**": true,
        "web/coverage/**": true
    },
}
