[submodule "tests/repo3/third_party/embedded-gcov"]
	path = tests/repo3/third_party/embedded-gcov
	url = https://github.com/nasa-jpl/embedded-gcov
	# The embedded-coverage build patches this third-party fixture's sources
	# in place every run (gcc-12+ compat for gcov_gcc.c/.h, gcov_printf.c), so
	# its worktree is perpetually "dirty" with non-committable churn. Ignore
	# that churn for status/diff (so `make release`'s bump-my-version sees a
	# clean tree) while still reporting a real change of the pinned commit.
	ignore = dirty
