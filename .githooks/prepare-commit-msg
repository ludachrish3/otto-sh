#!/usr/bin/env bash
# prepare-commit-msg
#
# Two interactive prompts on `git commit`:
#   1. Commit type prefix (feat/fix/chore/...) — prepended to the subject.
#      Skipped if the message already starts with a Conventional Commits
#      prefix (so re-edits and tool-generated commits like bump-my-version
#      are not double-prefixed).
#   2. AI assistance tag — added as an `Assisted-by:` trailer.
#
# Both prompts skip for merge/squash/amend commits and `git commit -m "..."`.
#
# Install: cp prepare-commit-msg .git/hooks/prepare-commit-msg
#          chmod +x .git/hooks/prepare-commit-msg
#
# To share with your team, commit this file to .githooks/ and set:
#   git config core.hooksPath .githooks
# (otto-sh's `make dev` does this for you.)

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="$2"

# Skip automated commit sources (merges, squashes, amends, -m flag)
case "$COMMIT_SOURCE" in
    merge|squash|commit)
        exit 0
        ;;
esac

# ── Commit type prompt ────────────────────────────────────────────────────────
# Conventional Commits prefixes. Keep in sync with the table in
# docs/contributing.md > "Branching and commits".
TYPE_OPTIONS=(feat fix chore docs test refactor ci)
TYPE_LABELS=(
    "New feature"
    "Bug fix"
    "No production code change (tooling, deps, refactors)"
    "Documentation only"
    "Tests only"
    "Code restructuring, no behavior change"
    "CI/CD configuration"
)
TYPE_DEFAULT=3   # chore — safest default if you're unsure
TYPE_SKIP=$((${#TYPE_OPTIONS[@]} + 1))

# First non-comment line of the existing message — used to detect a
# pre-existing conventional prefix and skip the prompt in that case.
first_line=$(grep -m1 -v '^#' "$COMMIT_MSG_FILE" | head -n1)

# Regex must live in a variable so bash's `[[ =~ ]]` parses the parens as
# regex syntax rather than shell grouping. Reference unquoted below.
conventional_prefix_re='^(feat|fix|chore|docs|test|refactor|ci|build|perf|style|revert)(\([^)]+\))?!?:'

if [[ ! "$first_line" =~ $conventional_prefix_re ]]; then
    # Read from terminal directly — stdin is not available in git hooks
    exec < /dev/tty

    echo ""
    echo "Commit type (Conventional Commits):"
    for i in "${!TYPE_OPTIONS[@]}"; do
        num=$((i + 1))
        marker=""
        [ "$num" -eq "$TYPE_DEFAULT" ] && marker="  (default)"
        printf "  [%s] %-10s %s%s\n" "$num" "${TYPE_OPTIONS[$i]}:" "${TYPE_LABELS[$i]}" "$marker"
    done
    printf "  [%s] %-10s leave message as-is\n" "$TYPE_SKIP" "skip:"
    printf "Select [%s]: " "$TYPE_DEFAULT"
    read -r tchoice

    # Resolve empty input to the default
    [ -z "$tchoice" ] && tchoice="$TYPE_DEFAULT"

    if [[ "$tchoice" =~ ^[0-9]+$ ]] \
       && [ "$tchoice" -ge 1 ] \
       && [ "$tchoice" -le "${#TYPE_OPTIONS[@]}" ]; then
        prefix="${TYPE_OPTIONS[$((tchoice - 1))]}: "
        # Prepend without trailing newline — first line becomes "<prefix> "
        # followed by whatever was on the original first line (typically blank).
        tmp=$(mktemp)
        printf '%s' "$prefix" > "$tmp"
        cat "$COMMIT_MSG_FILE" >> "$tmp"
        mv "$tmp" "$COMMIT_MSG_FILE"
    fi
    # Skip option or invalid input → leave the message untouched.

    exec < /dev/null
fi

# ── Options for AI assistance prompt ──────────────────────────────────────────
# OPT_NONE and OPT_CUSTOM are sentinel values — they drive behavior, not tags.
# OPT_DEFAULT controls which option number is selected on empty input.
OPT_NONE="None"
OPT_CLAUDE_OPUS="Claude Opus 4.7"
OPT_CLAUDE_SONNET="Claude Sonnet 4.6"
OPT_CUSTOM="Custom"
OPT_DEFAULT=1   # Options are 1-indexed

OPTIONS=(
    "$OPT_NONE"             # 1
    "$OPT_CLAUDE_OPUS"      # 2
    "$OPT_CLAUDE_SONNET"    # 3
    "$OPT_CUSTOM"           # 4
)
# ──────────────────────────────────────────────────────────────────────────────

# Read from terminal directly — stdin is not available in git hooks
exec < /dev/tty

echo ""
echo "╭────────── AI assistance used in this commit? ──────────╮"
echo "│                                                        │"
for i in "${!OPTIONS[@]}"; do
    num=$((i + 1))
    label="${OPTIONS[$i]}"
    if [ "$num" -eq "$OPT_DEFAULT" ]; then
        printf "│  [%s] %-50s│\n" "$num" "$label  (default)"
    else
        printf "│  [%s] %-50s│\n" "$num" "$label"
    fi
done
echo "│                                                        │"
echo "╰────────────────────────────────────────────────────────╯"
printf "  Select [%s]: " "$OPT_DEFAULT"
read -r choice

# Resolve empty input to the default option number
[ -z "$choice" ] && choice="$OPT_DEFAULT"

# Validate numeric input is in range
if ! [[ "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt "${#OPTIONS[@]}" ]; then
    echo "  Invalid selection — skipping tag."
    exec < /dev/null
    exit 0
fi

selected="${OPTIONS[$((choice - 1))]}"

if [ "$selected" = "$OPT_NONE" ]; then
    exec < /dev/null
    exit 0
elif [ "$selected" = "$OPT_CUSTOM" ]; then
    printf "  Name: "
    read -r selected
    if [ -z "$selected" ]; then
        echo "  No name entered — skipping tag."
        exec < /dev/null
        exit 0
    fi
fi

AI_TAG="$selected"

exec < /dev/null

# Add as a properly formatted git trailer (blank line + Token: Value)
git interpret-trailers --in-place --trailer "Assisted-by: $AI_TAG" "$COMMIT_MSG_FILE"

exit 0
