# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Dummy files
tests/repo1/product/product

# Test artifacts (coverage data + HTML, JUnit XML)
reports/
*.gcno
*.gcda
# ...but keep the committed golden fixtures the embedded-collector unit tests
# decode against (a live mps2_an385 cov_dump capture + its known-good .gcda).
!tests/unit/fixtures/embedded_coverage/*.gcda
!tests/unit/fixtures/embedded_coverage/*.gcno

# otto CLI per-subcommand output dirs — timestamped run artifacts written at
# the repo root by `otto test|host|cov|run|monitor|docker`. Root-anchored so
# they never shadow tests/ or src/otto/.
/test/
/host/
/cov/
/run/
/monitor/
/docker/

# Performance files
profile.txt

# Sphinx build output
docs/_build

# Build-time GUI media (scripts/capture_docs_media.py) — never committed
docs/_static/generated/

# Claude files
.claude

# Superpowers SDD scratch (task briefs, reports, diffs, progress ledger)
.superpowers/

# Generated JSON Schema (otto schema export default output)
/schemas/

# web/ (React+TS monitor dashboard) build output + deps — regenerated by
# `make web-install` / `make web`; see Makefile web-* targets.
src/otto/monitor/static/dist/
src/otto/coverage/renderer/static/dist/
web/node_modules/
