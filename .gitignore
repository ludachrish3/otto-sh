# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Dummy files
tests/repo1/product/product

# Test artifacts (coverage data + HTML, JUnit XML)
reports/
*.gcno
*.gcda
# ...but keep the committed golden fixtures the embedded-collector unit tests
# decode against (a live mps2_an385 cov_dump capture + its known-good .gcda).
!tests/unit/fixtures/embedded_coverage/*.gcda
!tests/unit/fixtures/embedded_coverage/*.gcno

# otto CLI per-subcommand output dirs — timestamped run artifacts written at
# the repo root by `otto test|host|cov|run|monitor|docker`. Root-anchored so
# they never shadow tests/ or src/otto/.
/test/
/host/
/cov/
/run/
/monitor/
/docker/

# Performance files
profile.txt

# Sphinx build output
docs/_build

# Claude files
.claude

# Generated JSON Schema (otto schema export default output)
/schemas/
