{
  "name": "otto-monitor-web",
  "private": true,
  "version": "0.1.0",
  "description": "React+TS frontend for the otto monitor dashboard, built to src/otto/monitor/static/dist/.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:covreport": "vite build --config vite.covreport.config.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "knip": "knip",
    "e2e:coverage-report": "node scripts/e2e_coverage_report.mjs",
    "coverage:merged": "nyc report --temp-dir ../reports/ts-cov/final --report-dir ../reports/ts-cov/html --reporter text --reporter html --check-coverage --statements 91 --branches 78 --functions 94 --lines 95"
  },
  "dependencies": {
    "@fontsource-variable/inter": "5.2.8",
    "@internationalized/date": "3.12.2",
    "@react-stately/utils": "3.12.1",
    "@tailwindcss/vite": "4.3.2",
    "@untitledui/file-icons": "0.0.9",
    "@untitledui/icons": "0.0.22",
    "@xyflow/react": "12.11.2",
    "echarts": "6.1.0",
    "input-otp": "1.4.2",
    "react": "19.2.7",
    "react-aria": "3.50.0",
    "react-aria-components": "1.19.0",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.3",
    "tailwindcss-animate": "1.0.7",
    "tailwindcss-react-aria-components": "2.2.0",
    "wouter": "3.10.0",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@bcoe/v8-coverage": "1.0.2",
    "@biomejs/biome": "2.5.3",
    "@jridgewell/sourcemap-codec": "1.5.5",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.9",
    "jsdom": "29.1.1",
    "json-schema-to-typescript": "15.0.4",
    "knip": "6.27.0",
    "monocart-coverage-reports": "2.12.12",
    "nyc": "18.0.0",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.9"
  }
}
